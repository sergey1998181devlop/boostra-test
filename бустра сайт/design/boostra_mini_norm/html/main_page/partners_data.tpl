<link href="design/{$settings->theme}/css/partners_page.css?v=1.0" rel="stylesheet" type="text/css" >
<div class="page">
    <p class="page__subtitle">
        Займы оформляются через лицензированные микрофинансовые компании — партнёры сервиса Boostra.
    </p>
    <div class="partners-list">
        {foreach $partners as $partner}
            <article class="partner-card">
                <div class="partner-card__main">
                    <div class="partner-card__name-row">
                        <div class="partner-card__name">{$partner.brand}</div>
                        {if $partner.recommend == 1}<span class="partner-card__badge">Рекомендуем</span>{/if}
                    </div>
                    <div class="partner-card__legal">
                        {$partner.legal_entity}<br>
                        ОГРН {$partner.ogrn}, ИНН {$partner.inn}
                    </div>
                    <div class="partner-card__links">
                        <a class="partner-card__link" href="{$partner.official_site}" target="_blank" rel="noopener">
                            Официальный сайт
                        </a>
                        <a class="partner-card__link" href="{$partner.documents_url}" target="_blank" rel="noopener">
                            Документы и реквизиты
                        </a>
                    </div>
                </div>
                <div class="partner-card__actions">
                    <a class="partner-card__btn partner-card__btn--primary"
                       href="/init_user?amount=30000&period=16" target="_blank" rel="noopener">
                        Получить деньги
                    </a>
                </div>
            </article>
        {/foreach}
    </div>
</div>